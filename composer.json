{
    "name": "voltstack/spa-lab",
    "description": "The SPA Lab Package for VoltStack Framework",
    "license": "MIT",
    "keywords": [
        "voltstack",
        "spa",
        "php"
    ],
    "authors": [
        {
            "name": "Francisco J. Morales",
            "email": "francisco.morales@voltstack.net"
        }
    ],
    "homepage": "https://voltstack.net",
    "require": {
        "php": "^8.3",
        "voltstack/framework": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../voltstack-framework",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "VoltStack\\SPALab\\": "src",
            "VoltStack\\SPALab\\Pages\\": "app/Pages/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VoltStack\\SPALab\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
